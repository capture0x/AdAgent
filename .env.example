# AdAgent — Environment Configuration
# Copy this file to .env and fill in your engagement details.
# Never commit .env to version control.

# ── Target ────────────────────────────────────────────────────
DC_IP=
DC_FQDN=
DOMAIN=
BASE_DN=

# ── Credentials ───────────────────────────────────────────────
USERNAME=
PASSWORD=
NT_HASH=

# ── Kerberos ──────────────────────────────────────────────────
USE_KERBEROS=false
KRB5_CCACHE=
KRB5_CONFIG=/etc/krb5.conf
TGT_AUTO_RENEW=true

# ── Attacker ──────────────────────────────────────────────────
ATTACKER_IP=
ATTACKER_IFACE=tun0

# ── Engagement ────────────────────────────────────────────────
ENGAGEMENT_NAME=
OUTPUT_DIR=output

# ── AI Backend ────────────────────────────────────────────────
# Set ANTHROPIC_API_KEY to use Claude. Leave blank to use Ollama (local/free).
ANTHROPIC_API_KEY=

# ── Agent Settings ────────────────────────────────────────────
# OPSEC mode: loud | normal | stealth
ADSTRIKE_OPSEC=normal

# ADSTRIKE_AGENT_LIVE_COMMANDS=true   — actually execute commands (default: true)
# AGENT_CLEAN_OUTPUT_ON_START=true    — wipe agent_runtime/ on each run
# AGENT_ARCHIVE_OLD_RUNS=true         — archive previous agent logs

# ── Secrets ───────────────────────────────────────────────────
# ADSTRIKE_SHOW_SECRETS=false         — show real creds in reports (default: false/redacted)
